{
  "welcomeFile": "/index.html",
  "authenticationMethod": "none",
  "routes": [
    {
      "source": "^/resources/(.*)$",
      "target": "/resources/$1",
      "destination": "ui5"
    },
    {
      "source": "^/test-resources/(.*)$",
      "target": "/test-resources/$1",
      "destination": "ui5"
    },
    {
      "source": "^/sap/(.*)$",
      "target": "/sap/$1",
      "destination": "S4_API"
    }
  ]
}