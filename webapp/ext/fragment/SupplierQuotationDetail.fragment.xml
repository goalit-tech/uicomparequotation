<uiTable:Table
        id="_IDGenSQDetailFragmentTable"
        selectionMode="None"
        enableSelectAll="false"
        rows="{LocalModel>/ActualSupplierQuotationItem}"
        enableCellFilter="true"
        filter=".filterPrice"
        ariaLabelledBy="title"
    >
    <uiTable:noData>
        <Text id="_IDGenSQDetailFragmentTableNoData" text="No supplier quotations Item to Select" />
    </uiTable:noData>
        <uiTable:columns>
            <uiTable:Column
                id="_IDGenSQDetailFragmentColumn"
                width="9rem"
                sortProperty="SupplierQuotation"
                filterProperty="SupplierQuotation"
            >
                <Label
                    id="_IDGenSQDetailFragmentLabel9"
                    text="Supplier Quotation"
                    wrapping="true"
                />
                <uiTable:template>
                    <Text
                        id="_IDGenSQDetailFragmentText"
                        text="{LocalModel>SupplierQuotation}"
                    />
                </uiTable:template>
            </uiTable:Column>
            <uiTable:Column
                id="_IDGenSQDetailFragmentColumn1"
                width="11rem"
                sortProperty="SupplierName"
                filterProperty="SupplierName"
            >
                <Label
                    id="_IDGenSQDetailFragmentLabel10"
                    text="Supplier Name"
                    wrapping="true"
                />
                <uiTable:template>
                    <Text
                        id="_IDGenSQDetailFragmentText1"
                        text="{LocalModel>SupplierName}"
                        wrapping="true"
                    />
                </uiTable:template>
            </uiTable:Column>
            <uiTable:Column
                id="_IDGenSQDetailFragmentColumn2"
                width="9rem"
                sortProperty="SupplierCode"
                filterProperty="SupplierCode"
            >
                <Label
                    id="_IDGenSQDetailFragmentLabel11"
                    text="Supplier Code"
                    wrapping="true"
                />
                <uiTable:template>
                    <Text
                        id="_IDGenSQDetailFragmentText2"
                        text="{LocalModel>SupplierCode}"
                        wrapping="true"
                    />
                </uiTable:template>
            </uiTable:Column>
            <uiTable:Column
                id="_IDGenSQDetailFragmentColumn3"
                width="6rem"
                sortProperty="RequestForQuotationItem"
                filterProperty="RequestForQuotationItem"
            >
                <Label
                    id="_IDGenSQDetailFragmentLabel12"
                    text="Item No"
                    wrapping="true"
                />
                <uiTable:template>
                    <Text
                        id="_IDGenSQDetailFragmentText3"
                        text="{LocalModel>RequestForQuotationItem}"
                    />
                </uiTable:template>
            </uiTable:Column>
            <uiTable:Column
                id="_IDGenSQDetailFragmentColumn4"
                width="11rem"
                sortProperty="PurchasingDocumentItemText"
                filterProperty="PurchasingDocumentItemText"
            >
                <Label
                    id="_IDGenSQDetailFragmentLabel13"
                    text="Material Description"
                    wrapping="true"
                />
                <uiTable:template>
                    <Text
                        id="_IDGenSQDetailFragmentText4"
                        text="{LocalModel>PurchasingDocumentItemText}"
                        wrapping="true"
                    />
                </uiTable:template>
            </uiTable:Column>
            <uiTable:Column
                id="_IDGenSQDetailFragmentColumn5"
                width="8rem"
                sortProperty="Material"
                filterProperty="Material"
            >
                <Label
                    id="_IDGenSQDetailFragmentLabel14"
                    text="Material"
                    wrapping="true"
                />
                <uiTable:template>
                    <Text
                        id="_IDGenSQDetailFragmentText5"
                        text="{LocalModel>Material}"
                        wrapping="true"
                    />
                </uiTable:template>
            </uiTable:Column>
            <uiTable:Column
                id="_IDGenSQDetailFragmentColumn6"
                width="6rem"
                sortProperty="ScheduleLineOrderQuantity"
                filterProperty="ScheduleLineOrderQuantity"
            >
                <Label
                    id="_IDGenSQDetailFragmentLabel15"
                    text="Quantity"
                    wrapping="true"
                />
                <uiTable:template>
                    <Text
                        id="_IDGenSQDetailFragmentText6"
                        text="{LocalModel>ScheduleLineOrderQuantity}"
                    />
                </uiTable:template>
            </uiTable:Column>
            <uiTable:Column
                id="_IDGenSQDetailFragmentColumn7"
                width="8rem"
                sortProperty="BaseUnit"
                filterProperty="BaseUnit"
            >
                <Label
                    id="_IDGenSQDetailFragmentLabel16"
                    text="Base Unit of Measure"
                    wrapping="true"
                />
                <uiTable:template>
                    <Text
                        id="_IDGenSQDetailFragmentText7"
                        text="{LocalModel>BaseUnit}"
                    />
                </uiTable:template>
            </uiTable:Column>
            <uiTable:Column
                id="_IDGenSQDetailFragmentColumn8"
                width="8rem"
                sortProperty="NetPriceAmount"
                filterProperty="NetPriceAmount"
            >
                <Label
                    id="_IDGenSQDetailFragmentLabel17"
                    text="Total value"
                    wrapping="true"
                />
                <uiTable:template>
                    <Text
                        id="_IDGenSQDetailFragmentText8"
                        text="{LocalModel>NetPriceAmount}"
                    />
                </uiTable:template>
            </uiTable:Column>
            <uiTable:Column
                id="_IDGenSQDetailFragmentColumn9"
                width="8rem"
                sortProperty="NetAmount"
                filterProperty="NetAmount"
            >
                <Label
                    id="_IDGenSQDetailFragmentLabel18"
                    text="Total value"
                    wrapping="true"
                />
                <uiTable:template>
                    <Text
                        id="_IDGenSQDetailFragmentText9"
                        text="{LocalModel>NetAmount}"
                    />
                </uiTable:template>
            </uiTable:Column>
            <uiTable:Column
                id="_IDGenSQDetailFragmentColumn10"
                width="8rem"
                sortProperty="ScheduleLineDeliveryDate"
                filterProperty="ScheduleLineDeliveryDate"
            >
                <Label
                    id="_IDGenSQDetailFragmentLabel19"
                    text="Delivery Date"
                />
                <uiTable:template>
                    <Text
                        id="_IDGenSQDetailFragmentText10"
                        text="{LocalModel>ScheduleLineDeliveryDate}"
                    />
                </uiTable:template>
            </uiTable:Column>
            <uiTable:Column
                id="_IDGenSQDetailFragmentColumn11"
                width="6rem"
                sortProperty="YY1_MaterialMake_PDI"
                filterProperty="YY1_MaterialMake_PDI"
            >
                <Label
                    id="_IDGenSQDetailFragmentLabel20"
                    text="Make"
                    wrapping="true"
                />
                <uiTable:template>
                    <Text
                        id="_IDGenSQDetailFragmentText11"
                        text="{LocalModel>YY1_MaterialMake_PDI}"
                        wrapping="true"
                    />
                </uiTable:template>
            </uiTable:Column>
            <uiTable:Column
                id="_IDGenSQDetailFragmentColumn12"
                width="6rem"
                sortProperty="YY1_Specifications_PDI"
                filterProperty="YY1_Specifications_PDI"
            >
                <Label
                    id="_IDGenSQDetailFragmentLabel21"
                    text="Specifications"
                    wrapping="true"
                />
                <uiTable:template>
                    <Text
                        id="_IDGenSQDetailFragmentText12"
                        text="{LocalModel>YY1_Specifications_PDI}"
                        wrapping="true"
                    />
                </uiTable:template>
            </uiTable:Column>
        </uiTable:columns>
    </uiTable:Table>

</core:FragmentDefinition>