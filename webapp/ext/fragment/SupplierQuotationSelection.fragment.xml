<core:FragmentDefinition
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:uiTable="sap.ui.table"
    xmlns:macros="sap.fe.macros"
    xmlns:smartTable="sap.ui.comp.smarttable"
    xmlns:core="sap.ui.core"
>
    <Dialog
        id="_IDGenSQFragmentDialog"
        title="Select Supplier Quotation Item for Comparison"
    >

<uiTable:Table
        id="_IDGenSQFragmentTable"
        selectionMode="MultiToggle"
        enableSelectAll="false"
        rows="{LocalModel>/SupplierQuotationItem}"
        enableCellFilter="true"
        filter=".filterPrice"
        ariaLabelledBy="title"
    >
    <uiTable:noData>
        <Text id="_IDGenSQFragmentTableNoData" text="No supplier quotations Item to Select" />
    </uiTable:noData>
        <uiTable:columns>
            <uiTable:Column
                id="_IDGenSQFragmentColumn"
                width="9rem"
                sortProperty="SupplierQuotation"
                filterProperty="SupplierQuotation"
            >
                <Label
                    id="_IDGenSQFragmentLabel9"
                    text="Supplier Quotation"
                    wrapping="true"
                />
                <uiTable:template>
                    <Text
                        id="_IDGenSQFragmentText"
                        text="{LocalModel>SupplierQuotation}"
                    />
                </uiTable:template>
            </uiTable:Column>
            <uiTable:Column
                id="_IDGenSQFragmentColumn1"
                width="11rem"
                sortProperty="SupplierName"
                filterProperty="SupplierName"
            >
                <Label
                    id="_IDGenSQFragmentLabel10"
                    text="Supplier Name"
                    wrapping="true"
                />
                <uiTable:template>
                    <Text
                        id="_IDGenSQFragmentText1"
                        text="{LocalModel>SupplierName}"
                        wrapping="true"
                    />
                </uiTable:template>
            </uiTable:Column>
            <uiTable:Column
                id="_IDGenSQFragmentColumn2"
                width="9rem"
                sortProperty="SupplierCode"
                filterProperty="SupplierCode"
            >
                <Label
                    id="_IDGenSQFragmentLabel11"
                    text="Supplier Code"
                    wrapping="true"
                />
                <uiTable:template>
                    <Text
                        id="_IDGenSQFragmentText2"
                        text="{LocalModel>SupplierCode}"
                        wrapping="true"
                    />
                </uiTable:template>
            </uiTable:Column>
            <uiTable:Column
                id="_IDGenSQFragmentColumn3"
                width="6rem"
                sortProperty="RequestForQuotationItem"
                filterProperty="RequestForQuotationItem"
            >
                <Label
                    id="_IDGenSQFragmentLabel12"
                    text="Item No"
                    wrapping="true"
                />
                <uiTable:template>
                    <Text
                        id="_IDGenSQFragmentText3"
                        text="{LocalModel>RequestForQuotationItem}"
                    />
                </uiTable:template>
            </uiTable:Column>
            <uiTable:Column
                id="_IDGenSQFragmentColumn4"
                width="11rem"
                sortProperty="PurchasingDocumentItemText"
                filterProperty="PurchasingDocumentItemText"
            >
                <Label
                    id="_IDGenSQFragmentLabel13"
                    text="Material Description"
                    wrapping="true"
                />
                <uiTable:template>
                    <Text
                        id="_IDGenSQFragmentText4"
                        text="{LocalModel>PurchasingDocumentItemText}"
                        wrapping="true"
                    />
                </uiTable:template>
            </uiTable:Column>
            <uiTable:Column
                id="_IDGenSQFragmentColumn5"
                width="8rem"
                sortProperty="Material"
                filterProperty="Material"
            >
                <Label
                    id="_IDGenSQFragmentLabel14"
                    text="Material"
                    wrapping="true"
                />
                <uiTable:template>
                    <Text
                        id="_IDGenSQFragmentText5"
                        text="{LocalModel>Material}"
                        wrapping="true"
                    />
                </uiTable:template>
            </uiTable:Column>
            <uiTable:Column
                id="_IDGenSQFragmentColumn6"
                width="6rem"
                sortProperty="ScheduleLineOrderQuantity"
                filterProperty="ScheduleLineOrderQuantity"
            >
                <Label
                    id="_IDGenSQFragmentLabel15"
                    text="Quantity"
                    wrapping="true"
                />
                <uiTable:template>
                    <Text
                        id="_IDGenSQFragmentText6"
                        text="{LocalModel>ScheduleLineOrderQuantity}"
                    />
                </uiTable:template>
            </uiTable:Column>
            <uiTable:Column
                id="_IDGenSQFragmentColumn7"
                width="8rem"
                sortProperty="BaseUnit"
                filterProperty="BaseUnit"
            >
                <Label
                    id="_IDGenSQFragmentLabel16"
                    text="Base Unit of Measure"
                    wrapping="true"
                />
                <uiTable:template>
                    <Text
                        id="_IDGenSQFragmentText7"
                        text="{LocalModel>BaseUnit}"
                    />
                </uiTable:template>
            </uiTable:Column>
            <uiTable:Column
                id="_IDGenSQFragmentColumn8"
                width="8rem"
                sortProperty="NetPriceAmount"
                filterProperty="NetPriceAmount"
            >
                <Label
                    id="_IDGenSQFragmentLabel17"
                    text="Total value"
                    wrapping="true"
                />
                <uiTable:template>
                    <Text
                        id="_IDGenSQFragmentText8"
                        text="{LocalModel>NetPriceAmount}"
                    />
                </uiTable:template>
            </uiTable:Column>
            <uiTable:Column
                id="_IDGenSQFragmentColumn9"
                width="8rem"
                sortProperty="NetAmount"
                filterProperty="NetAmount"
            >
                <Label
                    id="_IDGenSQFragmentLabel18"
                    text="Total value"
                    wrapping="true"
                />
                <uiTable:template>
                    <Text
                        id="_IDGenSQFragmentText9"
                        text="{LocalModel>NetAmount}"
                    />
                </uiTable:template>
            </uiTable:Column>
            <uiTable:Column
                id="_IDGenSQFragmentColumn10"
                width="8rem"
                sortProperty="ScheduleLineDeliveryDate"
                filterProperty="ScheduleLineDeliveryDate"
            >
                <Label
                    id="_IDGenSQFragmentLabel19"
                    text="Delivery Date"
                />
                <uiTable:template>
                    <Text
                        id="_IDGenSQFragmentText10"
                        text="{LocalModel>ScheduleLineDeliveryDate}"
                    />
                </uiTable:template>
            </uiTable:Column>
            <uiTable:Column
                id="_IDGenSQFragmentColumn11"
                width="6rem"
                sortProperty="YY1_MaterialMake_PDI"
                filterProperty="YY1_MaterialMake_PDI"
            >
                <Label
                    id="_IDGenSQFragmentLabel20"
                    text="Make"
                    wrapping="true"
                />
                <uiTable:template>
                    <Text
                        id="_IDGenSQFragmentText11"
                        text="{LocalModel>YY1_MaterialMake_PDI}"
                        wrapping="true"
                    />
                </uiTable:template>
            </uiTable:Column>
            <uiTable:Column
                id="_IDGenSQFragmentColumn12"
                width="6rem"
                sortProperty="YY1_Specifications_PDI"
                filterProperty="YY1_Specifications_PDI"
            >
                <Label
                    id="_IDGenSQFragmentLabel21"
                    text="Specifications"
                    wrapping="true"
                />
                <uiTable:template>
                    <Text
                        id="_IDGenSQFragmentText12"
                        text="{LocalModel>YY1_Specifications_PDI}"
                        wrapping="true"
                    />
                </uiTable:template>
            </uiTable:Column>
        </uiTable:columns>
    </uiTable:Table>

           <buttons>
            <Button
                id="_IDGenSQFragmentAddButton"
                text="Add"
                press=".onAddSQFragmentAddPress"
            />
            <Button
                id="_IDGenSQFragmentCancelButton"
                text="Cancel"
                press=".onAddSQFragmentCancelPress"
            />
        </buttons>
    </Dialog>
</core:FragmentDefinition>