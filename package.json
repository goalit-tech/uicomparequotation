{
  "name": "uicomparequotation",
  "version": "0.0.1",
  "description": "Manage Compare Quotation",
  "keywords": [
    "ui5",
    "openui5",
    "sapui5"
  ],
  "main": "webapp/index.html",
  "devDependencies": {
    "@sap-ux/eslint-plugin-fiori-tools": "^10.0.0",
    "@sap-ux/ui5-middleware-fe-mockserver": "2",
    "@sap/ux-ui5-tooling": "1",
    "@ui5/cli": "^4.0.33",
    "eslint": "^10",
    "mbt": "^1.2.49"
  },
  "scripts": {
    "start": "fiori run --open \"/test/flpSandbox.html?sap-ui-xx-viewCache=false#nlabaiuicomparequotation-tile\"",
    "start-local": "fiori run --config ./ui5-local.yaml --open \"/test/flpSandbox.html?sap-ui-xx-viewCache=false#nlabaiuicomparequotation-tile\"",
    "build": "ui5 build --config=ui5.yaml --clean-dest --dest dist",
    "lint": "eslint ./",
    "start-mock": "fiori run --config ./ui5-mock.yaml --open \"/test/flpSandbox.html?sap-ui-xx-viewCache=false#nlabaiuicomparequotation-tile\"",
    "deploy": "fiori verify",
    "deploy-config": "fiori add deploy-config",
    "start-noflp": "fiori run --open \"/index.html?sap-ui-xx-viewCache=false\"",
    "int-test": "fiori run --config ./ui5-mock.yaml --open \"/test/integration/opaTests.qunit.html\"",
    "start-variants-management": "fiori run --open \"/preview.html?sap-ui-xx-viewCache=false&fiori-tools-rta-mode=true&sap-ui-rta-skip-flex-validation=true#nlabaiuicomparequotation-tile\""
  },
  "sapuxLayer": "CUSTOMER_BASE",
  "sapux": true
}
